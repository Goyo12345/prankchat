{
  "name": "prankchat",
  "version": "1.0.0",
  "description": "Envoie des vannes à tes amis en temps réel",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.prankchat.app",
    "productName": "PrankChat",
    "artifactName": "PrankChat-Setup.${ext}",
    "extraResources": [
      {
        "from": "yt-dlp.exe",
        "to": "yt-dlp.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "index.html",
      "overlay.html",
      "obs.html",
      "config.js",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "keywords": [],
  "author": "Mirco",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.0.12"
  }
}
